{
  "manifest_version": 3,
  "name": "Interview Copilot Overlay",
  "version": "1.0.0",
  "description": "Floating real-time interview practice assistant with explicit start/stop controls.",
  "permissions": ["activeTab", "tabs", "storage"],
  "host_permissions": ["http://localhost:8080/*", "https://*/*", "http://*/*"],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Interview Copilot"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}
